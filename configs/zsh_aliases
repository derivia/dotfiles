# change commit date
rlcd() {
    local day=""
    local time=""
    local tz="$(date '+%z')"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --day)
                day="$2"
                shift 2
                ;;
            --time)
                time="$2"
                shift 2
                ;;
            --tz)
                tz="$2"
                shift 2
                ;;
            *)
                echo "Unknown option: $1"
                echo 'Usage: rlcd [--day "YYYY-MM-DD"] [--time "HH:MM:SS"] [--tz "+ZZZZ"]'
                return 1
                ;;
        esac
    done

    [[ -z "$day" ]]  && day="$(date '+%Y-%m-%d')"
    [[ -z "$time" ]] && time="$(date '+%H:%M:%S')"

    local date="$day $time $tz"

    GIT_COMMITTER_DATE="$date" git commit --amend --no-edit --date="$date"
}

# show tip of remote and local
rlb() {
    emulate -L zsh
    setopt LOCAL_OPTIONS NO_XTRACE NO_VERBOSE NO_WARN_CREATE_GLOBAL TYPESET_SILENT

    local RED=$'\033[31m'
    local GRN=$'\033[32m'
    local YLW=$'\033[33m'
    local PNK=$'\033[35m'
    local DIM=$'\033[2m'
    local RST=$'\033[0m'

    local current_branch
    current_branch=$(git symbolic-ref --short HEAD 2>/dev/null)

    local -A branches
    local b

    for b in $(git for-each-ref --format='%(refname:short)' refs/heads); do
        branches[$b]=1
    done

    for b in $(git for-each-ref --format='%(refname:lstrip=3)' refs/remotes/origin); do
        [[ "$b" == "HEAD" ]] && continue
        branches[$b]=1
    done

    local tmpfile
    tmpfile=$(mktemp)

    for b in ${(k)branches}; do
        local l_time="" l_user=""
        local r_time="" r_user=""

        if git rev-parse --verify -q "refs/heads/$b" >/dev/null; then
            l_time=$(git log -1 --format='%ct' "$b")
            l_user=$(git log -1 --format='%an' "$b")
        fi

        if git rev-parse --verify -q "refs/remotes/origin/$b" >/dev/null; then
            r_time=$(git log -1 --format='%ct' "origin/$b")
            r_user=$(git log -1 --format='%an' "origin/$b")
        fi

        local sort_time=0
        [[ -n "$l_time" && "$l_time" -gt "$sort_time" ]] && sort_time=$l_time
        [[ -n "$r_time" && "$r_time" -gt "$sort_time" ]] && sort_time=$r_time

        printf "%s|%s|%s|%s|%s|%s\n" \
            "$sort_time" "$b" "$l_time" "$l_user" "$r_time" "$r_user" >> "$tmpfile"
    done

    sort -t'|' -nr "$tmpfile" | while IFS='|' read -r sort_time b l_time l_user r_time r_user; do
        local l_str="-" r_str="-" st
        local l_mark="" r_mark=""

        [[ -n "$l_time" ]] && \
            l_str="$(date -d "@$l_time" '+%Y-%m-%d %H:%M') • $l_user"

        [[ -n "$r_time" ]] && \
            r_str="$(date -d "@$r_time" '+%Y-%m-%d %H:%M') • $r_user"

        # mark newer side
        if [[ -n "$l_time" && -n "$r_time" ]]; then
            if (( l_time > r_time )); then
                l_mark=" ${PNK}[*]${RST}"
            elif (( r_time > l_time )); then
                r_mark=" ${PNK}[*]${RST}"
            fi
        fi

        if [[ -n "$l_time" && -n "$r_time" ]]; then
            local l_hash r_hash
            l_hash=$(git rev-parse "$b")
            r_hash=$(git rev-parse "origin/$b")

            if [[ "$l_hash" == "$r_hash" ]]; then
                st="${GRN}[=]${RST}"
            else
                st="${YLW}[≠]${RST}"
            fi
        elif [[ -n "$l_time" ]]; then
            st="${RED}[∅]${RST}"
            r_str="${DIM}-${RST}"
        else
            st="${RED}[∅]${RST}"
            l_str="${DIM}-${RST}"
        fi

        local prefix=" "
        [[ "$b" == "$current_branch" ]] && prefix="*"

        printf "%s%s %b\n" "$prefix" "$b" "$st"
        printf "    local  %s%s\n" "$l_str" "$l_mark"
        printf "    remote %s%s\n\n" "$r_str" "$r_mark"
    done

    rm -f "$tmpfile"
}

# list pushed and local-only commits for each branch
rlcl() {
    emulate -L zsh
    setopt LOCAL_OPTIONS TYPESET_SILENT NO_XTRACE
    local since=""
    local limit=5
    local first=1
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --since)
                since="$2"; shift 2 ;;
            --hours)
                since="$(date -d "-$2 hours" '+%Y-%m-%d %H:%M:%S')"
                shift 2 ;;
            -N|--limit)
                limit="$2"; shift 2 ;;
            *)
                echo "Unknown option: $1"
                return 1 ;;
        esac
    done
    [[ -z "$since" ]] && since="$(date -d '-24 hours' '+%Y-%m-%d %H:%M:%S')"
    local now="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "Showing commits since: $since"
    local -a remotes
    remotes=($(git remote))
    typeset -A seen_hashes
    seen_hashes=()
    git for-each-ref --format='%(refname:short)' refs/heads | while read -r branch; do
        typeset -A unpushed_data remote_has_branch
        unpushed_data=()
        remote_has_branch=()
        for remote in "${remotes[@]}"; do
            local remote_ref="refs/remotes/$remote/$branch"
            if git rev-parse --verify -q "$remote_ref" >/dev/null; then
                remote_has_branch[$remote]=1
                local hashes
                hashes="$(git rev-list "$branch" --not "$remote_ref" 2>/dev/null)"
                unpushed_data[$remote]=" ${(j: :)${(f)hashes}} "
            else
                remote_has_branch[$remote]=0
                unpushed_data[$remote]=""
            fi
        done
        local branch_output=""
        local nl=$'\n'
        local raw
        raw=$(git log "$branch" \
                --since="$since" \
                --until="$now" \
                -n "$limit" \
                --date=format:'%Y-%m-%d %H:%M' \
            --pretty=format:'%H%x00%h%x00%ad%x00%an%x00%s%x00')
        local -a records
        records=(${(0)raw})
        local i=1
        while (( i + 4 <= ${#records} )); do
            local full_hash="${records[i]}"
            local short_hash="${records[i+1]}"
            local date="${records[i+2]}"
            local author="${records[i+3]}"
            local subject="${records[i+4]}"
            (( i += 5 ))
            # Skip commits we've already displayed under a previous branch
            if (( ${+seen_hashes[$full_hash]} )); then
                continue
            fi
            seen_hashes[$full_hash]=1
            local status_str=""
            for remote in "${remotes[@]}"; do
                local state
                if [[ "${remote_has_branch[$remote]}" -eq 0 ]] ||
                [[ "${unpushed_data[$remote]}" == *" $full_hash "* ]]; then
                    state=$'\033[31m[L]\033[0m'
                else
                    state=$'\033[32m[P]\033[0m'
                fi
                status_str+="${status_str:+, }$remote $state"
            done
            branch_output+="${branch_output:+$nl}$(
        printf '%s %s %s (%s) %s' \
        "$short_hash" "$date" "$author" "$status_str" "$subject"
      )"
        done
        if [[ -n "$branch_output" ]]; then
            (( first == 0 )) && echo
            first=0
            echo "Branch: $branch"
            print -r -- "$branch_output"
        fi
    done
}

gfh() {
    if [[ -z "$1" ]]; then
        echo "Usage: gfh <file>"
        return 1
    fi

    git log --follow \
        --pretty=format:'%C(yellow)%h%Creset | %Cgreen%ad%Creset | %Cblue%an%Creset | %s' \
        --date=short -- "$1"
}

