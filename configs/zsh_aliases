# adapted from https://github.com/dylanaraps/pure-bash-bible?tab=readme-ov-file#trim-leading-and-trailing-white-space-from-string
trim_string () {
    local input_string
    IFS= read -r -d '' input_string <&0
    local trimmed_string
    trimmed_string="${input_string#"${input_string%%[![:space:]]*}"}"
    trimmed_string="${trimmed_string%"${trimmed_string##*[![:space:]]}"}"
    printf '%s\n' "$trimmed_string"
}

