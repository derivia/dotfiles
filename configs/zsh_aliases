# convert all files in current working directory from one extension to another using ImageMagick
cvt() {
    if [ "$#" -ne 2 ]; then
        echo "Usage: cvt <source_extension> <target_extension>"
        return 1
    fi

    for file in *."$1"; do
        magick "$file" "${file%."$1"}.$2"
    done
}

epub2pdf() {
    local epub_file="$1"
    local pdf_file="${epub_file%.epub}.pdf"

    if [[ -z "$epub_file" ]]; then
        echo "Usage: epub2pdf <epub_file>"
        return 1
    fi

    if [[ ! -f "$epub_file" ]]; then
        echo "Error: File not found: $epub_file"
        return 1
    fi

    if command -v ebook-convert >/dev/null 2>&1; then
        echo "Converting '$epub_file' to '$pdf_file' using ebook-convert..."
        ebook-convert "$epub_file" "$pdf_file" --page-width 612 --page-height 792
        if [[ $? -eq 0 ]]; then
            echo "Conversion successful."
            return 0
        else
            echo "Error: ebook-convert failed.  Check the output for details."
            return 1
        fi
    else
        echo "Error: ebook-convert (from Calibre) is not installed.  Please install Calibre (https://calibre-ebook.com/) or another conversion tool like pandoc (if installed)."

        if command -v pandoc >/dev/null 2>&1; then
            echo "Attempting to convert '$epub_file' to '$pdf_file' using pandoc (fallback)..."
            pandoc "$epub_file" -o "$pdf_file" --pdf-engine=pdflatex
            if [[ $? -eq 0 ]]; then
                echo "Conversion (pandoc) successful."
                return 0
            else
                echo "Error: pandoc conversion failed. Check pandoc's output for more details."
                return 1
            fi
        else
            echo "Error: Neither ebook-convert nor pandoc is installed.  Please install one of them."
            return 1
        fi
    fi
}

